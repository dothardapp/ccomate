<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permiso necesario para acceder a recursos de red (videos HTTP/HTTPS) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Permisos para recibir trafico multicast UDP (IPTV) -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Soporte para dispositivos sin pantalla táctil (como Android TV) -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <!-- Soporte para Android TV (Leanback) -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />

    <application
        android:name=".CcoMateApplication"
        android:allowBackup="true"
        android:banner="@drawable/tv_banner_white"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CCOMate"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Actividad principal para lanzamiento en dispositivos móviles y Android TV -->
        <!--
            launchMode="singleTask": garantiza una sola instancia de MainActivity en el stack.
            Si el TCL Launcher o el sistema relanza la app mientras el proceso aún existe,
            Android enruta al onNewIntent() en vez de crear una segunda instancia — elimina
            el conflicto "two processes with the same name" reportado por TGuardMemoryClassifier.

            configChanges: evita que Android destruya y recree la Activity ante cambios de
            teclado/pantalla, lo que en TV puede ocurrir al conectar/desconectar mandos.
            La Activity maneja estos cambios internamente sin reinicio.
        -->
        <activity
            android:name=".activity.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="keyboard|keyboardHidden|navigation">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>



    </application>

</manifest>